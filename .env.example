# =============================================================================
# Polybot Hybrid — .env.example
# Copy to .env and fill in values. NEVER commit a real .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Trading mode
# -----------------------------------------------------------------------------
# LIVE_TRADING must be the literal string "true" to enable real orders.
# Anything else (unset, blank, "1", "yes", "True" with capital T) stays in
# paper mode. The --live CLI flag ALSO has to be passed; both gates are
# required.
LIVE_TRADING=false
# Legacy alias (honoured if LIVE_TRADING is unset): POLY_PAPER_MODE=false

# -----------------------------------------------------------------------------
# Polymarket wallet (L1 identity)
# -----------------------------------------------------------------------------
# Spec names (preferred):
POLYMARKET_PRIVATE_KEY=your_wallet_private_key_hex_no_0x_prefix
POLYMARKET_FUNDER_ADDRESS=0xYourWalletAddress
# Legacy aliases — still honoured if the POLYMARKET_* above are blank:
#   POLY_PRIVATE_KEY=...
#   POLY_FUNDER_ADDRESS=0x...

# -----------------------------------------------------------------------------
# Polymarket L2 API credentials (run: `python main.py setup-credentials`)
# -----------------------------------------------------------------------------
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Legacy aliases: POLY_API_KEY / POLY_API_SECRET / POLY_API_PASSPHRASE

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------
POLY_CHAIN_ID=137        # Polygon mainnet
POLY_SIGNATURE_TYPE=0    # 0=EOA, 1=Magic, 2=Safe

# -----------------------------------------------------------------------------
# Global risk caps (apply to ALL strategies)
# -----------------------------------------------------------------------------
TOTAL_CAPITAL=1000           # assumed bankroll in USDC for exposure calcs
MAX_EXPOSURE_PCT=0.30        # 30% of total capital at risk at once
MAX_TRADE_SIZE=100           # single-trade cap (USDC)
MAX_POSITION=50              # default position size for strategies
DAILY_LOSS_LIMIT=-50         # halt all trading if today's PnL drops below this
MAX_CORRELATED_OPEN=3        # BTC/ETH/SOL count as one correlation bucket

# -----------------------------------------------------------------------------
# Strategy 1: sub-$1 rebalancing arbitrage
# -----------------------------------------------------------------------------
ARB_MIN_EDGE=0.03            # require YES+NO < 1 - edge (3% buffer over 2% fee)
ARB_MIN_LIQUIDITY=2000       # USDC required on each side
ARB_SCAN_INTERVAL=3          # seconds between market scans
ARB_FEE_RATE=0.02            # winner-side fee
ARB_MARKET_LIMIT=200         # top-N markets to pull per scan

# -----------------------------------------------------------------------------
# Strategy 2: Binance → Polymarket latency arb
# -----------------------------------------------------------------------------
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
LATENCY_SYMBOLS=btcusdt,ethusdt,solusdt
LATENCY_MOMENTUM_PCT=0.0015  # 0.15% move in 30s triggers signal
LATENCY_WINDOW_SECS=30
LATENCY_UP_MAX_PRICE=0.60    # skip UP signal if YES already above this
LATENCY_DOWN_MIN_PRICE=0.40  # skip DOWN signal if YES already below this
LATENCY_TRADE_SIZE=50        # flat $ per trade

# -----------------------------------------------------------------------------
# Strategy 3: wallet copy trading
# -----------------------------------------------------------------------------
# Polygon RPC used for on-chain checks in live mode (public node OK for reads;
# use Alchemy / Infura for reliability).
ALCHEMY_RPC_URL=https://polygon-rpc.com
# Comma-separated lowercase wallet addresses to monitor.
COPY_WALLETS=
COPY_MIN_TRADES=50
COPY_LOOKBACK_DAYS=30
COPY_SIZE_FRACTION=0.25      # mirror 25% of target's size
COPY_SIZE_CAP=100            # paper-mode hard cap per copy trade
COPY_POLL_INTERVAL=20        # seconds between activity polls
COPY_MAX_PRICE_SLIP=0.05     # skip if market drifted > 5% since wallet's trade
COPY_MARKET_MIN_LIQ=1000     # USDC required each side
COPY_MARKET_MAX_EXPOSURE_PCT=0.10  # 10% of capital per market

# -----------------------------------------------------------------------------
# Telegram alerts (optional — leave blank to disable)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
DB_PATH=polymarket_trades.db
