# Polygon wallet (your Polymarket identity)
POLY_PRIVATE_KEY=your_wallet_private_key_hex_no_0x_prefix
POLY_FUNDER_ADDRESS=0xYourWalletAddress

# L2 API credentials (generated by setup_credentials() — run once)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Network
POLY_CHAIN_ID=137         # Polygon mainnet
POLY_SIGNATURE_TYPE=0     # 0=MetaMask/EOA, 1=Magic/email, 2=Safe proxy

# Paper trading flag (true = no real orders placed, simulate fills only)
POLY_PAPER_MODE=true

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
